{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Xero",
  "version": "0.1.0",
  "identifier": "dev.sn0w.xero",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Xero",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "font-src": ["'self'", "data:"],
        "img-src": ["'self'", "data:", "blob:", "project-asset:", "https:", "http:"],
        "media-src": ["'self'", "blob:", "project-asset:"],
        "object-src": ["'self'", "blob:", "project-asset:"],
        "frame-src": ["'self'", "blob:", "project-asset:"],
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost"],
        "base-uri": ["'self'"]
      },
      "devCsp": {
        "default-src": ["'self'", "http://localhost:3000"],
        "script-src": ["'self'", "'unsafe-eval'", "http://localhost:3000"],
        "style-src": ["'self'", "'unsafe-inline'", "http://localhost:3000"],
        "font-src": ["'self'", "data:", "http://localhost:3000"],
        "img-src": ["'self'", "data:", "blob:", "project-asset:", "https:", "http:"],
        "media-src": ["'self'", "blob:", "project-asset:"],
        "object-src": ["'self'", "blob:", "project-asset:"],
        "frame-src": ["'self'", "blob:", "project-asset:"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:3000",
          "ws://localhost:3000"
        ],
        "base-uri": ["'self'"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/scrcpy-server-v2.7.jar",
      "resources/solana-toolchain/**/*",
      "resources/xero-ios-helper"
    ]
  }
}
