{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cadence",
  "version": "0.1.0",
  "identifier": "dev.sn0w.cadence",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cadence",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["../public/icon-light-32x32.png"]
  }
}
