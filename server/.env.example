# Copy to `.env` (gitignored) and fill in. Loaded automatically by Dotenvy
# in dev/test via config/runtime.exs. In prod, set these in the host env.

# --- Phoenix endpoint ---
PHX_HOST=localhost
PORT=26140
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# --- Database ---
# Format: ecto://USER:PASS@HOST/DATABASE
DATABASE_URL=ecto://postgres:postgres@localhost:26132/xero_dev
POOL_SIZE=10
# Set to "true" or "1" to enable IPv6 socket option for the DB pool.
ECTO_IPV6=

# --- DNS clustering (libcluster-style discovery via dns_cluster) ---
DNS_CLUSTER_QUERY=

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for any (dev only).
CORS_ORIGINS=http://localhost:26100,http://127.0.0.1:26100,http://localhost:26102,http://127.0.0.1:26102,tauri://localhost

# --- Rate limiting (Hammer) ---
# Default per-IP cap for the :api scope. Override per-route in code.
RATE_LIMIT_PER_MINUTE=60

# --- Computer Use desktop streaming ---
# Comma-separated STUN/TURN URLs passed to WebRTC clients. TURN credentials use
# coturn REST auth and are issued by the relay with short TTLs.
XERO_WEBRTC_STUN_URLS=
XERO_TURN_URLS=
XERO_TURN_SHARED_SECRET=
XERO_TURN_TTL_SECONDS=600

# --- Oban ---
# Comma-separated queue:concurrency pairs.
OBAN_QUEUES=default:10,mailers:5

# --- Github ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
