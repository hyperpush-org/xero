{
  "name": "joe-dev-root",
  "private": true,
  "scripts": {
    "dev": "concurrently -n TAURI,LANDING -c magenta,cyan \"pnpm run dev:tauri\" \"pnpm run dev:landing\"",
    "dev:tauri": "pnpm --dir ./client exec tauri dev",
    "dev:landing": "pnpm --dir ./landing run dev --port 3001"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
