{
  "name": "xero-dev-root",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "node scripts/dev-preflight.mjs && concurrently -n DB,PHX,TAURI,LANDING -c blue,green,magenta,cyan -k \"pnpm run dev:db:logs\" \"pnpm run dev:server\" \"pnpm run dev:tauri\" \"pnpm run dev:landing\"",
    "dev:preflight": "node scripts/dev-preflight.mjs",
    "dev:db": "node scripts/docker-compose.mjs -f server/docker-compose.yml up",
    "dev:db:logs": "node scripts/docker-compose.mjs -f server/docker-compose.yml logs -f --tail=20 postgres",
    "dev:server": "cd server && mix phx.server",
    "dev:tauri": "pnpm --dir ./client run tauri:dev",
    "dev:tauri:ios-grpc": "pnpm --dir ./client run tauri:dev:ios-grpc",
    "dev:landing": "pnpm --dir ./landing run dev --port 3001",
    "start": "node scripts/start-preflight.mjs && node scripts/build-tauri-if-stale.mjs && concurrently -n DB,PHX,APP -c blue,green,magenta -k \"pnpm run dev:db:logs\" \"pnpm run start:server\" \"node scripts/launch-built-app.mjs\"",
    "start:preflight": "node scripts/start-preflight.mjs",
    "start:build": "node scripts/build-tauri-if-stale.mjs",
    "start:rebuild": "node scripts/build-tauri-if-stale.mjs --rebuild",
    "start:server": "cd server && MIX_ENV=prod XERO_LAUNCH_MODE=local-source mix phx.server",
    "performance:smoke": "pnpm --dir ./client run performance:smoke",
    "rust:test": "pnpm --dir ./client run rust:test",
    "rust:target:prune": "pnpm --dir ./client run rust:target:prune",
    "rust:target:prune:dry-run": "pnpm --dir ./client run rust:target:prune:dry-run",
    "agent-system:verify-plan": "node scripts/verify-agent-system-plan.mjs",
    "db:up": "node scripts/docker-compose.mjs -f server/docker-compose.yml up -d",
    "db:down": "node scripts/docker-compose.mjs -f server/docker-compose.yml down",
    "db:reset": "cd server && mix ecto.reset",
    "server:setup": "cd server && mix setup"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
